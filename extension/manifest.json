{
  "manifest_version": 3,
  "name": "Z-Ticket · Enriquecimento Crisp (CNPJ)",
  "version": "1.3.1",
  "description": "Lê o cabeçalho da conversa no Crisp (Contato - Empresa), busca o CNPJ no Z-Ticket e grava a etiqueta CNPJ nos dados da conversa.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://app.crisp.chat/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.crisp.chat/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Z-Ticket Crisp",
    "default_popup": "popup.html"
  }
}
