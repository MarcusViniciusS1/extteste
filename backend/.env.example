DATABASE_URL=postgresql://postgres:admin@localhost:5432/zorte_tickets
# Back-end (API Node/Express). Copie para .env e ajuste conforme seu Postgres local.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=admin
PGDATABASE=zorte_tickets
API_PORT=3001

# Integração com o Claude (Anthropic). Cole sua chave aqui (começa com sk-ant-).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Crisp (extensão de navegador) — token de plugin no formato identifier:key.
CRISP_IDENTIFIER=
CRISP_KEY=

# Linear (linear.app) — Signing Secret do webhook (Linear > Settings > API > Webhooks).
# Sem isso definido, o endpoint POST /api/linear/webhook aceita qualquer pedido
# (modo dev). Defina antes de expor o webhook publicamente.
LINEAR_WEBHOOK_SECRET=
