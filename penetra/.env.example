# Copie este arquivo para ".env" e preencha com os seus dados.
# Este arquivo (.env.example) VAI para o Git como modelo — por isso
# NUNCA coloque valores reais aqui. Os segredos reais ficam so no .env.

# Tokens do plugin (Crisp Marketplace > seu plugin > Tokens)
# Use o "Development token" enquanto desenvolve; troque pelo "Production token" ao publicar.
CRISP_PLUGIN_IDENTIFIER=coloque_o_identifier_aqui
CRISP_PLUGIN_KEY=coloque_o_key_aqui

# Signing Secret (mesma aba Tokens) — usado para validar os pedidos do Crisp.
CRISP_SIGNING_SECRET=coloque_o_signing_secret_aqui

# Enquanto testa, deixe false. Depois de confirmar a formula, mude para true.
VERIFY_SIGNATURE=false

# URL publica do backend depois do deploy (ex.: https://seu-app.onrender.com)
PUBLIC_URL=

# Porta em que o servidor vai rodar (a maioria dos provedores define isso sozinho)
PORT=3000
